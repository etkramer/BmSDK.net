---
// Reproduces the marketing site's BrandMark (blue `{}` tile + white wordmark)
// so the docs logo matches the home page. Plain CSS since Panda isn't loaded here.
const { siteTitleHref } = Astro.locals.starlightRoute
---

<a href={siteTitleHref} class="site-title">
  <span class="brand-tile">{'{}'}</span>
  <span class="brand-name">BmSDK</span>
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }
  .brand-tile {
    display: grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 6px;
    background: #2f81f7;
    color: #fff;
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .brand-name {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
  }
</style>
