---
import { Code } from 'astro:components'
import { css, cx } from 'styled-system/css'
import { surface } from 'styled-system/recipes'
import { codeSample } from '@/data/snippet'
---

<div
  class={cx(
    surface({ tone: 'inset' }),
    css({
      overflow: 'hidden',
      boxShadow: '0 16px 40px -12px rgba(1, 4, 9, 0.6)',
    })
  )}
>
  <div
    class={css({
      display: 'flex',
      alignItems: 'center',
      gap: '2',
      px: '4',
      h: '11',
      borderBottom: '1px solid',
      borderColor: 'border.default',
      bg: 'bg.subtle',
    })}
  >
    <div class={css({ display: 'flex', gap: '1.5' })}>
      <span class={css({ w: '3', h: '3', borderRadius: 'full', bg: '#ff5f56' })}></span>
      <span class={css({ w: '3', h: '3', borderRadius: 'full', bg: '#ffbd2e' })}></span>
      <span class={css({ w: '3', h: '3', borderRadius: 'full', bg: '#27c93f' })}></span>
    </div>
    <span
      class={css({
        ml: '2',
        fontSize: 'xs',
        color: 'fg.muted',
        fontFamily: 'mono',
      })}
    >
      {codeSample.filename}
    </span>
  </div>

  <div
    class={css({
      p: '5',
      overflowX: 'auto',
      fontSize: 'sm',
      lineHeight: 'relaxed',
      '& pre': { background: 'transparent !important', margin: '0' },
      '& code': { fontFamily: 'mono' },
    })}
  >
    <Code code={codeSample.code} lang={codeSample.lang} theme="github-dark" />
  </div>
</div>
