---
import { css } from 'styled-system/css'
import { iconTile } from 'styled-system/recipes'
import Section from '@/components/layout/Section.astro'
import SectionHeading from '@/components/layout/SectionHeading.astro'
import { features } from '@/data/features'
---

<Section bg="subtle">
  <SectionHeading
    title="Development"
    subtitle="BmSDK aims to be a fully idiomatic C# SDK, yet familiar to modders who might have some experience in UnrealScript. Developer convenience/tooling is a huge priority."
  />

  <div
    class={css({
      mt: '12',
      display: 'grid',
      gridTemplateColumns: { base: '1fr', md: 'repeat(3, 1fr)' },
      gap: { base: '10', md: '8' },
    })}
  >
    {
      features.map((feature) => (
        <div>
          <div class={iconTile({ size: 'md', tone: 'muted' })}>
            <feature.icon size={20} />
          </div>
          <h3
            class={css({ mt: '5', fontSize: 'lg', fontWeight: 'semibold', color: 'fg.default' })}
            set:html={feature.title}
          />
          <p
            class={css({ mt: '2', fontSize: 'sm', lineHeight: 'relaxed', color: 'fg.muted' })}
            set:html={feature.body}
          />
        </div>
      ))
    }
  </div>
</Section>
