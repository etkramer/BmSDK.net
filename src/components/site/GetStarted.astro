---
import { css, cx } from 'styled-system/css'
import { surface } from 'styled-system/recipes'
import { Button } from '@/components/ui/button'
import { Download, ArrowUpRight } from '@/lib/icons'
import Section from '@/components/layout/Section.astro'
import SectionHeading from '@/components/layout/SectionHeading.astro'
import { steps } from '@/data/steps'
import { links } from '@/data/site'
---

<Section
  id="get-started"
  bg="subtle"
  class={css({
    display: 'grid',
    gridTemplateColumns: { base: '1fr', lg: '1fr 1fr' },
    gap: { base: '10', lg: '16' },
    alignItems: 'center',
  })}
>
  <div>
    <SectionHeading
      title="Getting started"
      subtitle="If you just want to play script mods, you don’t need to build anything. Install the release, then add scripts as you find them."
      subtitleClass={css({ maxW: '32rem' })}
    />

    <div class={css({ mt: '8', display: 'flex', flexWrap: 'wrap', gap: '3' })}>
      <a href="#download">
        <Button size="lg">
          <Download size={18} />
          Download BmSDK
        </Button>
      </a>
      <a href={links.docs.firstMod}>
        <Button variant="ghost" colorPalette="gray" size="lg">
          Write your first mod
          <ArrowUpRight size={16} />
        </Button>
      </a>
    </div>
  </div>

  <ol
    class={css({
      display: 'flex',
      flexDirection: 'column',
      gap: '3',
      listStyle: 'none',
    })}
  >
    {
      steps.map((step, i) => (
        <li
          class={cx(
            surface({ radius: 'lg' }),
            css({ display: 'flex', gap: '4', alignItems: 'flex-start', p: '4' })
          )}
        >
          <span
            class={css({
              flexShrink: '0',
              display: 'grid',
              placeItems: 'center',
              w: '7',
              h: '7',
              borderRadius: 'full',
              bg: 'gh.neutralMuted',
              fontSize: 'sm',
              fontWeight: 'semibold',
              color: 'fg.default',
              fontFamily: 'mono',
            })}
          >
            {i + 1}
          </span>
          <span
            class={css({ fontSize: 'sm', lineHeight: 'relaxed', color: 'fg.muted', pt: '0.5' })}
            set:html={step}
          />
        </li>
      ))
    }
  </ol>
</Section>
