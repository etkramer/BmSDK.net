---
import { css } from 'styled-system/css'
import Container from '@/components/layout/Container.astro'
import BrandMark from '@/components/layout/BrandMark.astro'
import GithubIcon from '@/components/layout/GithubIcon.astro'
import { headerNav } from '@/data/navigation'
import { site, links } from '@/data/site'

const navLink = css({
  fontSize: 'sm',
  color: 'fg.muted',
  transition: 'color 0.15s',
  _hover: { color: 'fg.default' },
})
---

<header
  class={css({
    position: 'sticky',
    top: '0',
    zIndex: '50',
    bg: 'color-mix(in srgb, var(--colors-bg-canvas) 80%, transparent)',
    backdropFilter: 'blur(12px)',
  })}
>
  <Container
    class={css({
      h: '16',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
    })}
  >
    <a href={import.meta.env.BASE_URL} class={css({ display: 'inline-flex' })}>
      <BrandMark />
    </a>

    <nav class={css({ display: { base: 'none', md: 'flex' }, alignItems: 'center', gap: '6' })}>
      {
        headerNav.map((link) => (
          <a href={link.href} class={navLink}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      href={links.city.repo}
      aria-label={`${site.name} on GitHub`}
      class={css({
        display: 'flex',
        alignItems: 'center',
        gap: '2',
        color: 'fg.muted',
        transition: 'color 0.15s',
        _hover: { color: 'fg.default' },
      })}
    >
      <GithubIcon size={20} />
    </a>
  </Container>
</header>
