---
import { css } from 'styled-system/css'
import GithubIcon from './GithubIcon.astro'

const columns = [
  {
    title: 'Games',
    links: [
      { label: 'Arkham City', href: 'https://github.com/etkramer/BmSDK' },
      { label: 'Arkham Knight', href: 'https://github.com/etkramer/BmSDK-AK' },
    ],
  },
  {
    title: 'Docs',
    links: [
      { label: 'Wiki', href: 'https://github.com/etkramer/BmSDK/wiki' },
      {
        label: 'Your first mod',
        href: 'https://github.com/etkramer/BmSDK/wiki/Creating-your-first-mod',
      },
      {
        label: 'Building BmSDK',
        href: 'https://github.com/etkramer/BmSDK/wiki/Building-BmSDK',
      },
    ],
  },
  {
    title: 'Project',
    links: [
      {
        label: 'Releases',
        href: 'https://github.com/etkramer/BmSDK/releases/latest',
      },
      { label: 'GitHub', href: 'https://github.com/etkramer/BmSDK' },
      {
        label: 'Licence',
        href: 'https://github.com/etkramer/BmSDK/blob/master/LICENSE.md',
      },
    ],
  },
]
---

<footer
  class={css({
    borderTop: '1px solid',
    borderColor: 'border.subtle',
    bg: 'bg.canvas',
  })}
>
  <div
    class={css({
      maxW: '1080px',
      mx: 'auto',
      px: { base: '4', md: '6' },
      py: { base: '12', md: '16' },
      display: 'grid',
      gridTemplateColumns: { base: '1fr', sm: '1.5fr repeat(3, 1fr)' },
      gap: { base: '10', sm: '8' },
    })}
  >
    <div>
      <div
        class={css({
          display: 'flex',
          alignItems: 'center',
          gap: '2.5',
          fontWeight: 'bold',
          fontSize: 'lg',
          color: 'fg.default',
        })}
      >
        <span
          class={css({
            display: 'grid',
            placeItems: 'center',
            w: '7',
            h: '7',
            borderRadius: 'md',
            bg: 'accent.default',
            color: 'white',
            fontSize: 'sm',
            fontFamily: 'var(--font-mono)',
          })}
        >
          {'{}'}
        </span>
        BmSDK
      </div>
      <a
        href="https://github.com/etkramer/BmSDK"
        aria-label="BmSDK on GitHub"
        class={css({
          mt: '5',
          display: 'inline-flex',
          color: 'fg.muted',
          transition: 'color 0.15s',
          _hover: { color: 'fg.default' },
        })}
      >
        <GithubIcon size={20} />
      </a>
    </div>

    {
      columns.map((column) => (
        <div>
          <h4
            class={css({
              fontSize: 'sm',
              fontWeight: 'semibold',
              color: 'fg.default',
            })}
          >
            {column.title}
          </h4>
          <ul
            class={css({
              mt: '3',
              display: 'flex',
              flexDirection: 'column',
              gap: '2.5',
              listStyle: 'none',
            })}
          >
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={css({
                    fontSize: 'sm',
                    color: 'fg.muted',
                    transition: 'color 0.15s',
                    _hover: { color: 'gh.link' },
                  })}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div
    class={css({
      borderTop: '1px solid',
      borderColor: 'border.subtle',
    })}
  >
    <div
      class={css({
        maxW: '1080px',
        mx: 'auto',
        px: { base: '4', md: '6' },
        py: '6',
        display: 'flex',
        flexWrap: 'wrap',
        gap: '3',
        justifyContent: 'space-between',
        alignItems: 'center',
        fontSize: 'xs',
        color: 'fg.subtle',
      })}
    >
      <span>Released under the MIT licence.</span>
      <span>
        Not affiliated with Warner Bros. Games or Rocksteady Studios.
      </span>
    </div>
  </div>
</footer>
