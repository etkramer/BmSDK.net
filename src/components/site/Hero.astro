---
import { css } from 'styled-system/css'
import { Button } from '@/components/ui/button'
import { Download, BookText } from '@/lib/icons'
import Container from '@/components/layout/Container.astro'
import CodePanel from './CodePanel.astro'
import { links } from '@/data/site'
---

<section>
  <Container
    class={css({
      pt: { base: '16', md: '24' },
      pb: { base: '16', md: '20' },
      display: 'grid',
      gridTemplateColumns: { base: '1fr', lg: '0.9fr 1.1fr' },
      gap: '12',
      alignItems: 'center',
    })}
  >
    <div>
      <h1
        class={css({
          fontSize: { base: '4xl', md: '6xl' },
          fontWeight: 'bold',
          lineHeight: '1.05',
          letterSpacing: 'tight',
          color: 'fg.default',
        })}
      >
        BmSDK:<br />
        <span class={css({ color: 'gh.link' })}>Arkham Modding SDK</span>
      </h1>

      <p
        class={css({
          mt: '6',
          fontSize: { base: 'md', md: 'lg' },
          lineHeight: 'relaxed',
          color: 'fg.muted',
          maxW: '30rem',
        })}
      >
        BmSDK is a scripting platform for Batman: Arkham City and Arkham Knight. Extend the game
        with custom gameplay and logic, using a full C# SDK built on the engine&rsquo;s own
        UnrealScript API.
      </p>

      <div class={css({ mt: '8', display: 'flex', flexWrap: 'wrap', gap: '3' })}>
        <a href="#get-started">
          <Button size="lg">
            <Download size={18} />
            Download
          </Button>
        </a>
        <a href={links.docs.home}>
          <Button variant="outline" colorPalette="gray" size="lg">
            <BookText size={18} />
            Documentation
          </Button>
        </a>
      </div>
    </div>

    <CodePanel />
  </Container>
</section>
